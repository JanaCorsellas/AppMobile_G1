<!DOCTYPE html>
<html>
<head>
    <title>Autenticación exitosa</title>
    <style>
        body { 
            font-family: Arial, sans-serif; 
            text-align: center; 
            padding: 50px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            margin: 0;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .container {
            background: rgba(255,255,255,0.1);
            padding: 40px;
            border-radius: 15px;
            backdrop-filter: blur(10px);
        }
        .success { 
            font-size: 24px; 
            margin-bottom: 20px;
        }
        .loading {
            font-size: 16px;
            opacity: 0.8;
        }
        .spinner {
            width: 30px;
            height: 30px;
            border: 3px solid rgba(255,255,255,0.3);
            border-top: 3px solid white;
            border-radius: 50%;
            animation: spin 1s linear infinite;
            margin: 20px auto;
        }
        @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="success">¡Autenticación exitosa!</div>
        <div class="spinner"></div>
        <div class="loading">Redirigiendo...</div>
    </div>
    
    <script>
        // Redirigir a la app principal después de 2 segundos
        setTimeout(() => {
            window.location.href = '/';
        }, 2000);
    </script>
</body>
</html>